# SEMDS v1.1 - Environment Variables Template
# 复制此文件为 .env 并填入实际值

# ============================================
# LLM API 配置 (选择一个即可)
# ============================================

# 选项 1: DeepSeek (推荐，国内友好，性价比高)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 选项 2: Anthropic Claude (代码能力强，需海外网络)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 选项 3: OpenAI (GPT-4，需海外网络)
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Ollama 本地模型配置 (用于本地小模型实验)
# ============================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:4b

# ============================================
# Consilium 决策引擎配置
# ============================================

CONSILIUM_BACKEND=deepseek
CONSILIUM_SAFETY_LEVEL=medium

# ============================================
# SEMDS 系统配置 (可选)
# ============================================

# SEMDS_DB_PATH=semds/storage/semds.db
# SEMDS_LOG_LEVEL=INFO
